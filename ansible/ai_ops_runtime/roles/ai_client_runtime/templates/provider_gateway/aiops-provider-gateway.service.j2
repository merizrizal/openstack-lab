[Unit]
Description=AI-OPS fail-closed provider gateway
After=network.target

[Service]
Type=simple
User={{ ai_ops_provider_gateway.user }}
Group={{ ai_ops_provider_gateway.group }}
WorkingDirectory={{ ai_ops_provider_gateway.root }}
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart={{ ai_ops_provider_gateway.root }}/venv/bin/python {{ ai_ops_provider_gateway.root }}/aiops_provider_gateway.py --policy {{ ai_ops_provider_gateway.root }}/gateway_policy.json
Restart=on-failure
RestartSec=5s
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET
CapabilityBoundingSet=
AmbientCapabilities=
LockPersonality=true

[Install]
WantedBy=multi-user.target
