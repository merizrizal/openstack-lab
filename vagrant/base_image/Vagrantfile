# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  base_image_name = ENV["BASE_IMAGE_NAME"]
  if base_image_name.nil?
    puts ">>>>> BASE_IMAGE_NAME need to be provided <<<<<"; \
    puts "Add BASE_IMAGE_NAME=this_name to the command"; \
    exit 1
  end

  use_ssh_key = ENV["USE_SSH_KEY"]
  if use_ssh_key.nil?
    config.ssh.username = "vagrant"
    config.ssh.password = "vagrant"
  end

  config.vm.define base_image_name do |d|
    d.vm.synced_folder ".", "/vagrant", disabled: true
  end

  if base_image_name.include?("ubuntu")
    config.vm.box = "bento/ubuntu-24.04"
    config.vm.box_version = "202508.03.0"
    config.vm.provision "shell", inline: <<-SHELL
      sudo apt update
      DEBIAN_FRONTEND=noninteractive apt -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" upgrade -y
      sudo update-grub
      sudo apt install qemu-guest-agent gcc cloud-init -y
      sudo useradd -m -s /bin/bash vagrant -u 1001 -g sudo
      echo "vagrant:vagrant" | sudo chpasswd
      sudo touch /etc/sudoers.d/00-sudo && sudo chmod 440 /etc/sudoers.d/00-sudo
      echo "%sudo ALL=(ALL) ALL" | sudo tee --append /etc/sudoers.d/00-sudo
      echo "vagrant ALL=(ALL) NOPASSWD: ALL" | sudo tee --append /etc/sudoers.d/00-sudo
    SHELL
  elsif base_image_name.include?("almalinux")
    config.vm.box = "almalinux/8"
    config.vm.box_version = "8.10.20260508"
    config.vm.provision "shell", inline: <<-SHELL
      sudo dnf -y --refresh update
      sudo dnf -y --refresh upgrade
      sudo dnf install qemu-guest-agent gcc cloud-init -y
      sudo groupadd sudo -g 1001
      sudo useradd -m -s /bin/bash vagrant -u 1001 -g 1001
      echo "vagrant:vagrant" | sudo chpasswd
      sudo touch /etc/sudoers.d/00-sudo && sudo chmod 440 /etc/sudoers.d/00-sudo
      echo "%sudo ALL=(ALL) ALL" | sudo tee --append /etc/sudoers.d/00-sudo
      echo "vagrant ALL=(ALL) NOPASSWD: ALL" | sudo tee --append /etc/sudoers.d/00-sudo
    SHELL
  else
    puts ">>>>> BASE_IMAGE_NAME: #{base_image_name} is not available <<<<<"; \
    exit 1
  end
end
